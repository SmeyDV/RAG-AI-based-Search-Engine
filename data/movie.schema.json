{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/khmer-movie.schema.json",
  "title": "Khmer Movie Dataset Record",
  "type": "object",
  "required": [
    "schema_version",
    "movie_id",
    "source_file",
    "title",
    "display_title",
    "alternate_titles",
    "year",
    "directors",
    "genres",
    "countries",
    "languages",
    "runtime_minutes",
    "cast",
    "source_urls",
    "plot",
    "overview",
    "awards",
    "reception",
    "raw_text"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "movie_id": { "type": "string", "minLength": 1 },
    "source_file": { "type": "string", "pattern": "\\.txt$" },
    "title": { "type": "string", "minLength": 1 },
    "display_title": { "type": "string", "minLength": 1 },
    "alternate_titles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "year": {
      "anyOf": [
        { "type": "integer", "minimum": 1888, "maximum": 2100 },
        { "type": "null" }
      ]
    },
    "directors": { "$ref": "#/$defs/stringList" },
    "genres": { "$ref": "#/$defs/stringList" },
    "countries": { "$ref": "#/$defs/stringList" },
    "languages": { "$ref": "#/$defs/stringList" },
    "runtime_minutes": {
      "anyOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "null" }
      ]
    },
    "cast": { "$ref": "#/$defs/stringList" },
    "source_urls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "uniqueItems": true
    },
    "plot": { "type": "string" },
    "overview": { "type": "string" },
    "awards": { "type": "string" },
    "reception": { "type": "string" },
    "raw_text": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
